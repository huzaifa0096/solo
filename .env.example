# Locus MCP — issued from your Locus developer dashboard
LOCUS_API_KEY=your-locus-api-key
LOCUS_MCP_URL=https://mcp.paywithlocus.com/mcp

# Anthropic — used for the customer-facing "deliverable" generation and the agent brain
ANTHROPIC_API_KEY=your-anthropic-api-key

# The wallet address that customers send USDC to (agent's Locus wallet, on Base)
SOLO_AGENT_WALLET=0x0000000000000000000000000000000000000000

# Per-day spending cap (USD) that the agent must respect — showcase Locus's control layer
SOLO_DAILY_SPEND_CAP_USD=20

# Vendor allowlist — what the agent is permitted to pay for. Comma-separated.
SOLO_VENDOR_ALLOWLIST=anthropic

# Public site URL (for share / callback links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
